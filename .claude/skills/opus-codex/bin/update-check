#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR=$(cd "$(dirname "$0")/.." && pwd)
LOCAL_VER=$(cat "$SCRIPT_DIR/VERSION" 2>/dev/null | tr -d '[:space:]')
CACHE_DIR="$HOME/.opus-codex"
CACHE_FILE="$CACHE_DIR/last-check"
CONFIG_FILE="$CACHE_DIR/config"
SNOOZE_FILE="$CACHE_DIR/snooze"

mkdir -p "$CACHE_DIR"

# Read config
AUTO_UPGRADE="false"
UPDATE_CHECK="true"
if [ -f "$CONFIG_FILE" ]; then
  AUTO_UPGRADE=$(grep -s '^auto_upgrade=' "$CONFIG_FILE" 2>/dev/null | cut -d= -f2 || echo "false")
  UPDATE_CHECK=$(grep -s '^update_check=' "$CONFIG_FILE" 2>/dev/null | cut -d= -f2 || echo "true")
fi

# Respect "never ask again"
if [ "$UPDATE_CHECK" = "false" ]; then
  exit 0
fi

# Respect snooze
if [ -f "$SNOOZE_FILE" ]; then
  SNOOZE_UNTIL=$(cat "$SNOOZE_FILE" 2>/dev/null | tr -d '[:space:]')
  NOW=$(date +%s)
  if [ "$NOW" -lt "$SNOOZE_UNTIL" ] 2>/dev/null; then
    exit 0
  fi
  rm -f "$SNOOZE_FILE"
fi

# Check cache (60 min TTL)
if [ -f "$CACHE_FILE" ]; then
  AGE=$(( $(date +%s) - $(stat -f %m "$CACHE_FILE" 2>/dev/null || stat -c %Y "$CACHE_FILE" 2>/dev/null || echo 0) ))
  if [ "$AGE" -lt 3600 ]; then
    cat "$CACHE_FILE"
    exit 0
  fi
fi

# Fetch remote version
REMOTE_VER=$(curl -sfL --max-time 3 "https://raw.githubusercontent.com/brian93512/opus-codex/refs/heads/main/VERSION" 2>/dev/null | tr -d '[:space:]') || exit 0

if [ -n "$REMOTE_VER" ] && [ "$LOCAL_VER" != "$REMOTE_VER" ]; then
  if [ "$AUTO_UPGRADE" = "true" ]; then
    echo "AUTO_UPGRADE $LOCAL_VER $REMOTE_VER" | tee "$CACHE_FILE"
  else
    echo "UPGRADE_AVAILABLE $LOCAL_VER $REMOTE_VER" | tee "$CACHE_FILE"
  fi
else
  echo -n "" > "$CACHE_FILE"
fi
